# ============================================================
# StoreAI Doctor - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=prod

# --- MySQL Database ---
DB_URL=jdbc:mysql://mysql:3306/storeai_doctor?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your-mysql-password-here
MYSQL_ROOT_PASSWORD=your-mysql-password-here
MYSQL_DATABASE=storeai_doctor

# --- JPA ---
JPA_DDL_AUTO=none

# --- DeepSeek AI ---
DEEPSEEK_API_KEY=sk-d3d8b384f607417aa35309bb807a1dce
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- JWT ---
JWT_SECRET=your-jwt-secret-key-here-at-least-32-chars
JWT_EXPIRATION=86400000

# --- Gumroad ---
GUMROAD_PRO_URL=https://gumroad.com/l/storeai-pro
GUMROAD_ENTERPRISE_URL=https://gumroad.com/l/storeai-enterprise
GUMROAD_PRO_PRODUCT_ID=pro
GUMROAD_ENTERPRISE_PRODUCT_ID=enterprise